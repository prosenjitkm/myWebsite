DB_HOST=localhost
DB_PORT=5432
DB_NAME=mywebsite
# Use the PostgreSQL superuser (postgres) or a dedicated user created via database/create_db_user.sql
DB_USER=admin
DB_PASSWORD=admin

# Generate with: openssl rand -hex 32
JWT_SECRET=your_256_bit_secret_here
JWT_EXPIRATION_MS=86400000

# Google OAuth2 — get these from https://console.cloud.google.com
# 1. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 2. Application type: Web application
# 3. Authorised redirect URI (local): http://localhost:8081/login/oauth2/code/google
# 4. Production redirect URI later: https://api.prosenjitkm.com/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

