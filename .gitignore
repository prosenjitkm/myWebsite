# Environment variables - NEVER commit these
.env
*.env
!.env.example

# Local Spring Boot profile with real secrets - NEVER commit
**/application-local.yaml
application-local.yaml

# GCP setup script is safe to commit (no hardcoded secrets, uses openssl/read)
# but ignore any output files it might create
gcp-setup-output.txt

# Logs
*.log
boot.log

# OS
.DS_Store
Thumbs.db

# IntelliJ IDEA - ignore the entire folder (contains local paths, secrets,
# run configs, and workspace state that must not be shared)
.idea/
*.iws
*.iml
*.ipr

# Maven / Spring Boot build output
HELP.md
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# STS
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# VS Code
.vscode/

# Generated / local build artefacts
backend/cp.txt

# Root-level backend strays — these belong ONLY inside backend/
# (guard against accidental duplication)
/pom.xml
/mvnw
/mvnw.cmd
/compose.yaml
/Dockerfile
/cp.txt
/boot.log
/.mvn/
/src/
/target/

